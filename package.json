{
  "name": "fitpilothq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port 3000",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "test:fits": "node --import tsx --test src/lib/fits/**/*.test.ts",
    "smoke:fits": "tsx scripts/run-fit-smoke.ts",
    "smoke:drake-sample": "tsx scripts/run-drake-sample-smoke.ts",
    "smoke:drake-runtime": "tsx scripts/run-drake-runtime-smoke.ts",
    "report:fit-coverage": "tsx scripts/report-fit-coverage.ts",
    "report:unknown-items": "tsx scripts/report-unknown-items.ts",
    "data:generate": "node scripts/generate-item-requirements.mjs",
    "data:validate": "node scripts/validate-datasets.mjs",
    "db:seed": "node prisma/seed.mjs",
    "db:prepare": "npm run data:generate && npm run data:validate && npm run db:seed",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "next": "^15.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "prisma": "^6.6.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2"
  }
}
